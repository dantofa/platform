{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.17.3/.schema/devbox.schema.json",
  "packages": [
    "uv@latest",
    "just@latest",
    "actionlint@latest",
    "yamllint@latest",
    "gh@latest",
    "ratchet@latest",
    "shellcheck@latest"
  ],
  "aliases": {
    "dctl": "uv run -- dctl"
  },
  "shell": {
    "init_hook": [
      "uv run -- pre-commit install -t pre-commit -t pre-push"
    ]
  }
}
