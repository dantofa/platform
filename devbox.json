{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.17.5/.schema/devbox.schema.json",
  "packages": [
    "uv@latest",
    "just@latest",
    "actionlint@latest",
    "yamllint@latest",
    "gh@latest",
    "ratchet@latest",
    "shellcheck@latest",
    "bws@latest",
    "kind@latest",
    "docker@latest",
    "kubectl@latest",
    "flux@latest"
  ],
  "env": {
    "KUBECONFIG": ".kubeconfig"
  },
  "aliases": {
    "dctl": "bws run --project-id 8adeb984-2d51-4701-bd80-b3a3018260ea -- uv run -- dctl",
    "kg": "kubectl get",
    "kd": "kubectl describe",
    "kl": "kubectl logs",
    "ke": "kubectl edit"
  },
  "shell": {
    "init_hook": ["uv run -- pre-commit install -t pre-commit -t pre-push"]
  }
}
